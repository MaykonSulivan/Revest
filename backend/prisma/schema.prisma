generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  name        String
  email       String   @unique
  password    String
  ultimoLogin DateTime?
  createdAt   DateTime @default(now())

  orders      Order[]
}

model Order {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  userId      Int

  user        User     @relation(fields: [userId], references: [id])

  productName String
  quantity    Int
  size        String?
  color       String?
  city        String?
  phone       String?
  note        String?

  total       Float
  entrada     Float
  restante    Float

  status      String   @default("Finalizado")
  createdAt   DateTime @default(now())
}